[PRIMER_SETTINGS]
# ==============================================================================
# GENERAL SETTINGS
# ==============================================================================
PRIMER_PICK_LEFT_PRIMER = 1
PRIMER_PICK_INTERNAL_OLIGO = 0
PRIMER_PICK_RIGHT_PRIMER = 1

# ==============================================================================
# LENGTH CONSTRAINTS
# ==============================================================================
# Target length: 20-24 bases
PRIMER_OPT_SIZE = 22
PRIMER_MIN_SIZE = 20
PRIMER_MAX_SIZE = 24

# ==============================================================================
# MELTING TEMPERATURE (Tm)
# ==============================================================================
# Target Tm: 50-60°C
PRIMER_OPT_TM = 62.0
PRIMER_MIN_TM = 58.0
PRIMER_MAX_TM = 66.0
# Max Tm difference between pair: 5°C
PRIMER_MAX_DIFF_TM = 5.0

# ==============================================================================
# GC CONTENT & CLAMPS
# ==============================================================================
# Target GC: 40-60%
PRIMER_MIN_GC = 40.0
PRIMER_MAX_GC = 60.0
PRIMER_OPT_GC = 50.0

# ==============================================================================
# STRICT START AND END CLAMPS
# ==============================================================================

# 1. START of Primer (5' End)
# This was your issue. The pattern matches the FIRST 5 bases (5' -> 3').
# 'S' = G or C (Strong). 'N' = Any.
# "SSNNN" forces the first 2 bases to be G or C.
PRIMER_MUST_MATCH_FIVE_PRIME = 'SSNNN'

# 2. END of Primer (3' End)
# Enforces that the 3' end (extension site) is a G or C.
# Set to 1 for at least 1 G/C (Standard).
# Set to 2 for at least 2 G/C (Very Strict).
PRIMER_GC_CLAMP = 2

# ==============================================================================
# RIGOROUS COMPLEMENTARITY (Prevents Dimers)
# ==============================================================================
# "4" means roughly 4 base pairs of homology allowed.
# These values are significantly tighter than default (8/8/8/3).

# Self-Complementarity (Hairpins/Self-dimers)
PRIMER_MAX_SELF_ANY = 4
PRIMER_MAX_SELF_END = 2

# Pair-Complementarity (Forward binds Reverse)
PRIMER_PAIR_MAX_COMPL_ANY = 4
PRIMER_PAIR_MAX_COMPL_END = 2

# ==============================================================================
# MISC
# ==============================================================================
# Limit homopolymer runs (e.g. GGGG)
PRIMER_MAX_POLY_X = 4
PRIMER_SALT_MONOVALENT = 50.0
PRIMER_DNA_CONC = 50.0
PRIMER_MAX_NS_ACCEPTED = 0

# Range as list of lists [[min, max]]
PRIMER_PRODUCT_SIZE_RANGE = [100, 300]
